<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:minHeight="@dimen/pt_row_min_height"
    android:paddingHorizontal="@dimen/pt_row_h_padding"
    android:paddingVertical="@dimen/pt_row_v_padding"
    android:background="?attr/selectableItemBackground">

    <!-- Drag handle (visible in edit mode, replaces radio button) -->
    <ImageView
        android:id="@+id/dragHandle"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_drag_handle"
        app:tint="?attr/ptTextHint"
        android:scaleType="center"
        android:visibility="gone"
        android:contentDescription="Drag to reorder" />

    <RadioButton
        android:id="@+id/radioRegion"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_marginEnd="12dp"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:clickable="false"
        android:focusable="false" />

    <com.playtranslate.ui.RegionPreviewView
        android:id="@+id/regionPreview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp" />

    <TextView
        android:id="@+id/tvRegionLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        style="@style/Text.PT.RowTitle" />

    <!-- Delete button (visible in edit mode) -->
    <ImageView
        android:id="@+id/btnDeleteRegion"
        android:layout_width="44dp"
        android:layout_height="28dp"
        android:layout_marginStart="4dp"
        android:paddingHorizontal="10dp"
        android:src="@drawable/ic_close"
        app:tint="?attr/ptDanger"
        android:scaleType="centerInside"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:visibility="gone"
        android:contentDescription="Delete region" />

</LinearLayout>
