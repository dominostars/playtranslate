<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/ptBg">

    <!-- Toolbar: holds the close button and a "collapsed" copy of the
         headword that fades in as the big in-content headword scrolls
         off the top. The TextView starts at alpha=0 and is updated by
         a NestedScrollView listener in WordDetailBottomSheet. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/ptBg"
        android:paddingStart="16dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/tvDetailToolbarHeadword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="18sp"
            android:textColor="?attr/ptText"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:alpha="0" />

        <ImageButton
            android:id="@+id/btnBackDetail"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            app:tint="?attr/ptText"
            android:contentDescription="Close" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/detailScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/detailContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/pt_section_h_padding"
            android:paddingBottom="20dp" />

    </androidx.core.widget.NestedScrollView>

    <!-- Add-to-Anki bottom dock: 1dp top-border divider + accent-filled
         CTA button, matching the spec's "accent-filled, 56dp" style. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/ptBg">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/ptDivider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWordAddToAnki"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:minHeight="56dp"
            android:text="@string/btn_add_to_anki"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:backgroundTint="?attr/ptAccent"
            android:textColor="?attr/ptAccentOn"
            android:visibility="gone"
            app:icon="@drawable/ic_add"
            app:iconTint="?attr/ptAccentOn"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:cornerRadius="@dimen/pt_radius" />

    </LinearLayout>

</LinearLayout>
