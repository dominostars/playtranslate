<?xml version="1.0" encoding="utf-8"?>
<!-- Sentence-only Anki review sheet. Hosts SentenceAnkiContentFragment
     which renders the Original / Translation / Words / Screenshot
     groups. The toolbar shows "Add to <Deck>" since this sheet has no
     mode switch (no word side). -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/ptBg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBackReview"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:tint="?attr/ptTextMuted"
            android:contentDescription="@string/cd_back" />

        <TextView
            android:id="@+id/tvAnkiSheetTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/ptText"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/anki_sheet_title_new_card" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/ptDivider" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <!-- Stable scroll column with two named slots: a deck-row host
             that the Kotlin populates programmatically and a fragment
             host that the FragmentManager attaches the
             SentenceAnkiContentFragment into. Both use fixed XML ids so
             child-fragment restoration after rotation/process death
             lands in the same containers we created originally. -->
        <LinearLayout
            android:id="@+id/sentenceAnkiScrollColumn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/pt_section_h_padding"
            android:paddingBottom="20dp">

            <LinearLayout
                android:id="@+id/sentenceAnkiDeckHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <FrameLayout
                android:id="@+id/sentenceAnkiFragmentHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/ptBg">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/ptDivider" />

        <FrameLayout
            android:id="@+id/btnSendToAnki"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:minHeight="60dp"
            android:background="@drawable/bg_anki_save_button"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:duplicateParentState="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_save"
                    app:tint="?attr/ptAccentOn"
                    android:layout_marginEnd="12dp"
                    android:duplicateParentState="true"
                    android:importantForAccessibility="no" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:duplicateParentState="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/anki_save_button_label"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/ptAccentOn"
                        android:duplicateParentState="true" />

                    <TextView
                        android:id="@+id/tvAnkiSendSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="?attr/ptAccentOn"
                        android:duplicateParentState="true" />

                </LinearLayout>
            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</LinearLayout>
