<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout designed for the Ayn Thor bottom screen: 1080×1240 px ≈ 411×472 dp
    (density ~420 dpi). No outer scroll — each section has a fixed role and
    the results area fills the remaining vertical space with internal scrolling.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBgDark"
    tools:context=".MainActivity">

    <!-- ── Results container — hosts TranslationResultFragment ────────── -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/resultsContainer"
        android:name="com.playtranslate.ui.TranslationResultFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Region picker container (replaces results when active) ─────── -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/regionPickerContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Bottom action bar ─────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorBgSurface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorBgDivider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp">

            <!-- FrameLayout so btnTranslate and btnCapturing occupy the same slot -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <!-- Normal mode: filled Translate button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTranslate"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:backgroundTint="?attr/colorAccentPrimary"
                    android:textColor="?attr/colorTextOnAccent"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="6dp" />

                <!-- Live mode: outlined Capturing button (same slot, toggled via visibility) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCapturing"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:visibility="gone"
                    app:strokeColor="?attr/colorTextSecondary"
                    app:cornerRadius="6dp" />

            </FrameLayout>

            <!-- Hamburger menu button -->
            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="58dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_live_play"
                android:src="@drawable/ic_menu"
                android:tint="?attr/colorTextOnAccent"
                android:scaleType="center"
                android:contentDescription="Open menu" />

        </LinearLayout>

    </LinearLayout>

    <!-- Edit overlay: covers resultsContainer + bottomBar when editing original text -->
    <LinearLayout
        android:id="@+id/editOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="?attr/colorBgDark"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Editable text fills entire overlay; keyboard shows "Go" action -->
        <EditText
            android:id="@+id/etEditOriginal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="top|start"
            android:paddingHorizontal="14dp"
            android:paddingTop="12dp"
            android:textSize="24sp"
            android:textColor="?attr/colorTextPrimary"
            android:lineSpacingMultiplier="1.5"
            android:background="@null"
            android:inputType="textMultiLine"
            android:imeOptions="actionGo"
            android:scrollbars="vertical" />

    </LinearLayout>


    <!-- ── Floating action buttons (top-right, drawn above all content) ─── -->

    <!-- Onboarding overlay — shown until notification + capture permissions are set up -->
    <LinearLayout
        android:id="@+id/onboardingContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="?attr/colorBgSurface"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Page 1: Notification permission -->
        <LinearLayout
            android:id="@+id/pageNotif"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="28dp"
            android:visibility="visible">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_notif_title"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_notif_body"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </ScrollView>

            <Button
                android:id="@+id/btnGrantNotif"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:text="@string/btn_grant_permission"
                android:textSize="16sp"
                android:backgroundTint="?attr/colorAccentPrimary"
                android:textColor="?attr/colorTextOnAccent"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- Page 2a: Accessibility — single-screen devices (no screen recording option) -->
        <LinearLayout
            android:id="@+id/pageA11ySingle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="28dp"
            android:visibility="gone">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_a11y_single_title"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_a11y_single_body"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </ScrollView>

            <TextView
                android:id="@+id/tvA11yHintSingle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/onboarding_a11y_hint"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnOpenA11ySingle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_open_a11y_settings"
                android:textSize="16sp"
                android:backgroundTint="?attr/colorAccentPrimary"
                android:textColor="?attr/colorTextOnAccent"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- Page 2b: Accessibility / screen recording choice (multi-screen) -->
        <LinearLayout
            android:id="@+id/pageA11y"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="28dp"
            android:visibility="gone">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_a11y_title"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_a11y_body"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </ScrollView>

            <TextView
                android:id="@+id/tvA11yHintDual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/onboarding_a11y_hint"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnOpenA11y"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_open_a11y_settings"
                android:textSize="16sp"
                android:backgroundTint="?attr/colorAccentPrimary"
                android:textColor="?attr/colorTextOnAccent"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Slide-in menu overlay ──────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/menuOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Scrim (darkened background, dismisses menu on tap) -->
        <View
            android:id="@+id/menuScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80000000" />

        <!-- Menu panel (slides in from right) -->
        <LinearLayout
            android:id="@+id/menuPanel"
            android:layout_width="220dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:orientation="vertical"
            android:background="?attr/colorBgSurface"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:elevation="8dp">

            <!-- Settings -->
            <LinearLayout
                android:id="@+id/menuItemSettings"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings"
                    android:tint="?attr/colorTextPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="Settings"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Start/Stop Live -->
            <LinearLayout
                android:id="@+id/menuItemLive"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/menuItemLiveIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_play"
                    android:tint="?attr/colorTextPrimary" />

                <TextView
                    android:id="@+id/menuItemLiveLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="Start Live"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Capture Region -->
            <LinearLayout
                android:id="@+id/menuItemRegion"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_crop"
                    android:tint="?attr/colorTextPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="Capture Region"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Translations -->
            <LinearLayout
                android:id="@+id/menuItemTranslations"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_history"
                    android:tint="?attr/colorTextPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="Translations"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Close -->
            <LinearLayout
                android:id="@+id/menuItemClose"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_close"
                    android:tint="?attr/colorTextPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="Close"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="16sp" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Debug: detection state log (debug builds only) -->
    <TextView
        android:id="@+id/tvDetectionLog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:textColor="#AAFFAA"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:padding="6dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
