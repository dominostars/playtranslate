<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout designed for the Ayn Thor bottom screen: 1080×1240 px ≈ 411×472 dp
    (density ~420 dpi). No outer scroll — each section has a fixed role and
    the results area fills the remaining vertical space with internal scrolling.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBgDark"
    tools:context=".MainActivity">

    <!-- ── Results container — hosts TranslationResultFragment ────────── -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/resultsContainer"
        android:name="com.gamelens.ui.TranslationResultFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Bottom action bar ─────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorBgSurface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorBgDivider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangeRegion"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/btn_change_region"
                android:textStyle="bold"
                android:textSize="11sp"
                android:textAllCaps="false"
                android:maxLines="3"
                android:gravity="center"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:layout_marginEnd="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="?attr/colorTextSecondary"
                app:cornerRadius="6dp" />

            <!-- FrameLayout so btnTranslate and btnCapturing occupy the same slot -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <!-- Normal mode: filled Translate button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTranslate"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:backgroundTint="?attr/colorAccentPrimary"
                    android:textColor="?attr/colorTextOnAccent"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="6dp" />

                <!-- Live mode: outlined Capturing button (same slot, toggled via visibility) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCapturing"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:visibility="gone"
                    app:strokeColor="?attr/colorTextSecondary"
                    app:cornerRadius="6dp" />

            </FrameLayout>

            <!-- Live toggle: progress ring wrapping play/pause buttons -->
            <FrameLayout
                android:id="@+id/liveButtonContainer"
                android:layout_width="58dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/liveProgressRing"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_gravity="center"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:indicatorSize="56dp"
                    app:trackThickness="2dp"
                    app:indicatorColor="?attr/colorAccentPrimary" />

                <!-- Non-live: filled teal play button -->
                <ImageButton
                    android:id="@+id/btnLivePlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_live_play"
                    android:src="@drawable/ic_play"
                    android:tint="?attr/colorTextOnAccent"
                    android:scaleType="center"
                    android:contentDescription="Start live mode" />

                <!-- Live: outlined pause button -->
                <ImageButton
                    android:id="@+id/btnLivePause"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_live_pause"
                    android:src="@drawable/ic_pause"
                    android:scaleType="center"
                    android:visibility="gone"
                    android:contentDescription="Pause live mode" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Edit overlay: covers resultsContainer + bottomBar when editing original text -->
    <LinearLayout
        android:id="@+id/editOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="?attr/colorBgDark"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Editable text fills entire overlay; keyboard shows "Go" action -->
        <EditText
            android:id="@+id/etEditOriginal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="top|start"
            android:paddingHorizontal="14dp"
            android:paddingTop="12dp"
            android:textSize="24sp"
            android:textColor="?attr/colorTextPrimary"
            android:lineSpacingMultiplier="1.5"
            android:background="@null"
            android:inputType="textMultiLine"
            android:imeOptions="actionGo"
            android:scrollbars="vertical" />

    </LinearLayout>


    <!-- ── Floating action buttons (top-right, drawn above all content) ─── -->

    <!-- Settings gear: always visible -->
    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/btn_settings"
        android:src="@drawable/ic_settings"
        android:tint="?attr/colorTextSecondary"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Clear (X) — visible only when results are shown and not in live mode -->
    <ImageButton
        android:id="@+id/btnClear"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Clear"
        android:src="@drawable/ic_close"
        android:tint="?attr/colorTextSecondary"
        android:elevation="4dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnSettings" />

    <!-- Onboarding overlay — shown until notification + capture permissions are set up -->
    <LinearLayout
        android:id="@+id/onboardingContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="?attr/colorBgSurface"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Page 1: Notification permission -->
        <LinearLayout
            android:id="@+id/pageNotif"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="28dp"
            android:visibility="visible">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_notif_title"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_notif_body"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </ScrollView>

            <Button
                android:id="@+id/btnGrantNotif"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:text="@string/btn_grant_permission"
                android:textSize="16sp"
                android:backgroundTint="?attr/colorAccentPrimary"
                android:textColor="?attr/colorTextOnAccent"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- Page 2a: Accessibility — single-screen devices (no screen recording option) -->
        <LinearLayout
            android:id="@+id/pageA11ySingle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="28dp"
            android:visibility="gone">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_a11y_single_title"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_a11y_single_body"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </ScrollView>

            <Button
                android:id="@+id/btnOpenA11ySingle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:text="@string/btn_open_a11y_settings"
                android:textSize="16sp"
                android:backgroundTint="?attr/colorAccentPrimary"
                android:textColor="?attr/colorTextOnAccent"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- Page 2b: Accessibility / screen recording choice (multi-screen) -->
        <LinearLayout
            android:id="@+id/pageA11y"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="28dp"
            android:visibility="gone">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_a11y_title"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_a11y_body"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </ScrollView>

            <Button
                android:id="@+id/btnOpenA11y"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:text="@string/btn_open_a11y_settings"
                android:textSize="16sp"
                android:backgroundTint="?attr/colorAccentPrimary"
                android:textColor="?attr/colorTextOnAccent"
                app:cornerRadius="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/onboarding_a11y_alt"
                android:textColor="?attr/colorTextHint"
                android:textSize="11sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUseScreenRecord"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"
                android:text="@string/btn_use_screen_recording"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
