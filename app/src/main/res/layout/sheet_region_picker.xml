<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/ptBg">

    <!-- Toolbar: [Edit]  title  [+] -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnEditRegion"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:text="@string/label_edit"
            android:textColor="?attr/ptAccent"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <TextView
            android:id="@+id/tvRegionPickerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/label_select_region"
            android:textColor="?attr/ptText"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <Button
            android:id="@+id/btnAddRegion"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:text="+"
            android:textColor="?attr/ptAccent"
            android:textSize="22sp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/ptDivider" />

    <!-- No-preview notice (shown when accessibility is not enabled) -->
    <LinearLayout
        android:id="@+id/noPreviewNotice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="@dimen/pt_section_h_padding"
        android:paddingVertical="12dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/region_picker_no_preview"
            android:textColor="?attr/ptTextMuted"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="›"
            android:textColor="?attr/ptTextHint"
            android:textSize="18sp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Region list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/regionRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="@dimen/pt_section_h_padding"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:clipToPadding="false"
        android:clipChildren="false" />

</LinearLayout>
