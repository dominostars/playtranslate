<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable value row: title on left, current value + chevron on right. Tappable. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="66dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="@dimen/pt_row_h_padding"
    android:paddingVertical="@dimen/pt_row_v_padding"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/tvRowTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        style="@style/Text.PT.RowTitle" />

    <TextView
        android:id="@+id/tvRowValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        style="@style/Text.PT.RowValue" />

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_chevron_right"
        app:tint="?attr/ptTextMuted"
        android:importantForAccessibility="no" />

</LinearLayout>
