<?xml version="1.0" encoding="utf-8"?>
<!-- Word Anki review sheet. Hosts both Word and (optional) Sentence
     card flows. The toolbar slot to the right of the back button shows
     either a Sentence/Word segmented control (when sentence data is
     present) or a plain "Add to <Deck>" title. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/ptBg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <Button
            android:id="@+id/btnBackWordAnki"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="‹"
            android:textColor="?attr/ptAccent"
            android:textSize="40sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp" />

        <TextView
            android:id="@+id/tvWordAnkiSheetTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/ptText"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/anki_sheet_title_default" />

        <FrameLayout
            android:id="@+id/wordAnkiToolbarToggle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:visibility="gone" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/ptDivider" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/wordAnkiScrollContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/pt_section_h_padding"
            android:paddingBottom="20dp" />

    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/ptBg">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/ptDivider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWordAnkiSend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:minHeight="52dp"
            android:text="@string/btn_add_to_anki"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:backgroundTint="?attr/ptAccent"
            android:textColor="?attr/ptAccentOn"
            app:icon="@drawable/ic_add"
            app:iconTint="?attr/ptAccentOn"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:cornerRadius="@dimen/pt_radius" />

    </LinearLayout>

</LinearLayout>
