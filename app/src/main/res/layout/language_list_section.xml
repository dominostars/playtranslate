<?xml version="1.0" encoding="utf-8"?>
<!-- Grouped-card section for the language setup pages. Rows are inflated
     into `sectionRows` by LanguageSetupActivity; inset dividers separate
     rows and the card's cornerRadius clips first/last row corners. -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/ptCard"
    app:cardCornerRadius="@dimen/pt_radius"
    app:cardElevation="0dp"
    app:strokeColor="?attr/ptDivider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:id="@+id/sectionRows"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

</com.google.android.material.card.MaterialCardView>
