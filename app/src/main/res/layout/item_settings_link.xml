<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="10dp"
    android:paddingHorizontal="12dp"
    android:layout_marginVertical="2dp"
    android:clickable="true"
    android:focusable="true"
    android:background="@drawable/bg_link_row">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvLinkTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorAccentPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivLinkIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_open_in_new"
                android:tint="?attr/colorAccentPrimary"
                android:scaleType="centerInside"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvLinkSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorTextHint"
            android:textSize="14sp"
            android:layout_marginTop="1dp" />

    </LinearLayout>

</LinearLayout>
