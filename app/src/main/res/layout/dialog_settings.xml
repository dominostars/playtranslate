<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorBgSurface">

    <!-- Toolbar (shown only in dialog mode) -->
    <LinearLayout
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSettingsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_title"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCloseSettings"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="&#x2715;"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="18sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp" />

    </LinearLayout>

    <View
        android:id="@+id/settingsToolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorBgDivider"
        android:visibility="gone" />

    <!-- Scrollable content -->
    <ScrollView
        android:id="@+id/settingsScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- LANGUAGE                                                    -->
            <!-- ═══════════════════════════════════════════════════════════ -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LANGUAGE"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:alpha="0.38">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Japanese"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="14sp"
                    android:background="?attr/colorBgCard"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="10dp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="?attr/colorTextPrimary"
                    android:scaleType="centerInside"
                    android:layout_marginHorizontal="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="English"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="14sp"
                    android:background="?attr/colorBgCard"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="10dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_language_hint"
                android:textColor="?attr/colorTextHint"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- GAME SCREEN ICON                                            -->
            <!-- ═══════════════════════════════════════════════════════════ -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorBgDivider"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GAME SCREEN ICON"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <!-- Show icon toggle -->
            <LinearLayout
                android:id="@+id/rowOverlayIcon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">

                <!-- Left: title + hint with icon -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvOverlayIconTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_show_overlay_icon"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Hint row: icon aligned with hint text -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/ivFloatingIconPreview"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="2dp"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true"
                            android:contentDescription="@string/settings_show_overlay_icon" />

                        <TextView
                            android:id="@+id/tvOverlayIconHint"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_overlay_icon_hint_dual"
                            android:textColor="?attr/colorTextHint"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Right: switch centered with entire section -->
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchOverlayIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Wrapper for settings below the icon toggle (dimmed when icon is off on single-screen) -->
            <LinearLayout
                android:id="@+id/settingsBelowIcon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <!-- Small icon toggle -->
            <LinearLayout
                android:id="@+id/rowCompactIcon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Minimize icon"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchCompactIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- AUTO TRANSLATION                                            -->
            <!-- ═══════════════════════════════════════════════════════════ -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorBgDivider"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AUTO TRANSLATION"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <!-- Overlay Mode title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Overlay Mode"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- Overlay Mode toggle -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleAutoMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModeTranslate"
                    style="@style/Widget.PlayTranslate.SegmentedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Translate" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModeFurigana"
                    style="@style/Widget.PlayTranslate.SegmentedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Furigana" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:id="@+id/tvAutoModeHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="?attr/colorTextHint"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp" />

            <!-- Hide game screen overlays toggle (multi-screen only) -->
            <LinearLayout
                android:id="@+id/rowHideOverlays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="6dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hide game screen overlays"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Translations will only appear in PlayTranslate"
                        android:textColor="?attr/colorTextHint"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchHideOverlays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Hotkey: hold to show translations -->
            <LinearLayout
                android:id="@+id/rowHotkeyTranslation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hotkey: hold to show translations"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHotkeyTranslationHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Not set"
                        android:textColor="?attr/colorTextHint"
                        android:textSize="14sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchHotkeyTranslation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Hotkey: hold to show furigana -->
            <LinearLayout
                android:id="@+id/rowHotkeyFurigana"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="6dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hotkey: hold to show furigana"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHotkeyFuriganaHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Not set"
                        android:textColor="?attr/colorTextHint"
                        android:textSize="14sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchHotkeyFurigana"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Capture interval -->
            <LinearLayout
                android:id="@+id/rowCaptureInterval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Left: title + hint stacked -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Capture interval"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCaptureIntervalHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="?attr/colorTextHint"
                        android:textSize="14sp"
                        android:layout_marginTop="1dp" />

                </LinearLayout>

                <!-- Right: input + suffix -->
                <EditText
                    android:id="@+id/etCaptureInterval"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionDone"
                    android:textSize="14sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:background="?attr/colorBgCard"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="6dp"
                    android:gravity="center"
                    android:maxLength="3"
                    android:singleLine="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" s"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- CAPTURE DISPLAY (hidden when only one display)              -->
            <!-- ═══════════════════════════════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/llCaptureDisplaySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorBgDivider"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CAPTURE DISPLAY"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/llDisplayOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_display_hint"
                    android:textColor="?attr/colorTextHint"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- TRANSLATION SERVICE                                         -->
            <!-- ═══════════════════════════════════════════════════════════ -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorBgDivider"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TRANSLATION SERVICE (OPTIONAL)"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etDeeplKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:hint="@string/hint_deepl_key"
                android:textSize="14sp"
                android:textColor="?attr/colorTextPrimary"
                android:textColorHint="?attr/colorTextHint"
                android:background="?attr/colorBgCard"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp"
                android:fontFamily="monospace"
                android:singleLine="true" />

            <LinearLayout
                android:id="@+id/llDeeplLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp" />

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- ANKI                                                        -->
            <!-- ═══════════════════════════════════════════════════════════ -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorBgDivider"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvAnkiSectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ANKI"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/llAnkiGetApp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/llAnkiPermission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

            <Spinner
                android:id="@+id/spinnerAnkiDeck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorBgCard"
                android:popupBackground="?attr/colorBgCard"
                android:layout_marginTop="4dp"
                android:visibility="gone" />


            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- THEME                                                       -->
            <!-- ═══════════════════════════════════════════════════════════ -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorBgDivider"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="THEME"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/llThemePicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

            </LinearLayout> <!-- settingsBelowIcon -->

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- SUPPORT                                                      -->
            <!-- ═══════════════════════════════════════════════════════════ -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorBgDivider"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SUPPORT"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/llSupportLinks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- DEBUG (only in debug builds)                                -->
            <!-- ═══════════════════════════════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/llDebugSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorBgDivider"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DEBUG"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/rowForceSingleScreen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Force single-screen mode"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="14sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchForceSingleScreen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowShowOcrBoxes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Show OCR bounding boxes"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="14sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchShowOcrBoxes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowDetectionLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Show detection log"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="14sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchDetectionLog"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </LinearLayout>


        </LinearLayout>

    </ScrollView>

</LinearLayout>
