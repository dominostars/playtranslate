<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorBgSurface">

    <!-- Toolbar (shown only in dialog mode) -->
    <LinearLayout
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSettingsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_title"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCloseSettings"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="&#x2715;"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="18sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp" />

    </LinearLayout>

    <View
        android:id="@+id/settingsToolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorBgDivider"
        android:visibility="gone" />

    <!-- Scrollable content -->
    <ScrollView
        android:id="@+id/settingsScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Language selector -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:alpha="0.38">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Japanese"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="14sp"
                    android:background="?attr/colorBgCard"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="10dp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="?attr/colorTextPrimary"
                    android:scaleType="centerInside"
                    android:layout_marginHorizontal="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="English"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="14sp"
                    android:background="?attr/colorBgCard"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="10dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_language_hint"
                android:textColor="?attr/colorTextHint"
                android:textSize="10sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp" />

            <!-- Overlay icon toggle (highlighted card) -->
            <LinearLayout
                android:id="@+id/rowOverlayIcon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/colorBgCard"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvOverlayIconTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_show_overlay_icon"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <ImageView
                            android:id="@+id/ivFloatingIconPreview"
                            android:layout_width="36dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="8dp"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true"
                            android:contentDescription="@string/settings_show_overlay_icon" />

                        <TextView
                            android:id="@+id/tvOverlayIconHint"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_overlay_icon_hint_dual"
                            android:textColor="?attr/colorTextPrimary"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.4" />

                    </LinearLayout>

                </LinearLayout>

                <Switch
                    android:id="@+id/switchOverlayIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowCompactIcon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Small icon"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="14sp" />

                <Switch
                    android:id="@+id/switchCompactIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorBgDivider"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Capture method section (hidden when accessibility is enabled) -->
            <LinearLayout
                android:id="@+id/llCaptureMethodSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="?attr/colorBgCard"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Some Features Unavailable"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_capture_mp_limitations"
                    android:textColor="?attr/colorTextHint"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.3"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCaptureMethodOpenA11y"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/btn_enable_accessibility"
                    android:backgroundTint="?attr/colorAccentPrimary"
                    android:textColor="?attr/colorTextOnAccent"
                    android:textSize="12sp"
                    app:cornerRadius="6dp" />

            </LinearLayout>

            <!-- Capture method divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorBgDivider"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            </LinearLayout>


            <!-- Auto translation section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Auto Translation"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleAutoMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModeOverlays"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Overlays" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModeInApp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="In-App Only" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:id="@+id/tvAutoModeHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="?attr/colorTextHint"
                android:textSize="10sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Auto translation capture interval"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etCaptureInterval"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textSize="14sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:background="?attr/colorBgCard"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="6dp"
                    android:gravity="center"
                    android:maxLength="3"
                    android:singleLine="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" s"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="14sp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/tvCaptureIntervalHint"
                android:text=""
                android:textColor="?attr/colorTextHint"
                android:textSize="10sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp" />

            <!-- Display selector -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_display"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/llDisplayOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_display_hint"
                android:textColor="?attr/colorTextHint"
                android:textSize="10sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp" />

            <!-- DeepL section divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorBgDivider"
                android:layout_marginBottom="16dp" />

            <!-- DeepL API Key -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_deepl_key"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etDeeplKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:hint="@string/hint_deepl_key"
                android:textSize="12sp"
                android:textColor="?attr/colorTextPrimary"
                android:background="?attr/colorBgCard"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:singleLine="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_deepl_hint"
                android:textColor="?attr/colorTextHint"
                android:textSize="10sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"
                android:id="@+id/tvDeeplHint" />

            <!-- Anki section divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorBgDivider"
                android:layout_marginBottom="16dp" />

            <!-- Anki deck selector -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_anki_deck"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvAnkiDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/anki_section_description"
                android:textColor="?attr/colorTextHint"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvAnkiPlayStoreLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/anki_play_store_link"
                android:textColor="?attr/colorAccentPrimary"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvAnkiStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorTextHint"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <Spinner
                android:id="@+id/spinnerAnkiDeck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorBgCard"
                android:popupBackground="?attr/colorBgCard"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnGrantAnkiPermission"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:text="@string/btn_grant_anki_permission"
                android:backgroundTint="?attr/colorAccentPrimary"
                android:textColor="?attr/colorTextOnAccent"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Theme section divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorBgDivider"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Theme picker -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="THEME"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="12sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/llThemePicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp" />

            <!-- Debug-only section -->
            <LinearLayout
                android:id="@+id/llDebugSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorBgDivider"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DEBUG"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/rowForceSingleScreen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Force single-screen mode"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="14sp" />

                    <Switch
                        android:id="@+id/switchForceSingleScreen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowShowOcrBoxes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Show OCR bounding boxes"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="14sp" />

                    <Switch
                        android:id="@+id/switchShowOcrBoxes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowDetectionLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Show detection log"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="14sp" />

                    <Switch
                        android:id="@+id/switchDetectionLog"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
