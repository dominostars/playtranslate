<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/ptBg">

    <!-- Toolbar (shown only in dialog mode).
         liftOnScroll replaces the old static divider: a subtle surface-tint
         shadow appears when content scrolls under the toolbar. -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/ptBg"
        app:liftOnScroll="true"
        app:liftOnScrollTargetViewId="@id/settingsScrollView"
        android:visibility="gone">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/settingsToolbarInner"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:titleTextColor="?attr/ptText">

            <TextView
                android:id="@+id/tvSettingsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_title"
                android:textColor="?attr/ptText"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCloseSettings"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end"
                android:text="&#x2715;"
                android:textColor="?attr/ptText"
                android:textSize="18sp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp" />

        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/settingsScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/pt_section_h_padding"
            android:paddingTop="4dp"
            android:paddingBottom="20dp">

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- LANGUAGE                                              -->
            <!-- ══════════════════════════════════════════════════════ -->

            <include layout="@layout/settings_group_header"
                android:id="@+id/headerLanguage" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/ptCard"
                app:cardCornerRadius="@dimen/pt_radius"
                app:cardElevation="0dp"
                app:strokeColor="?attr/ptDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/settings_row_value"
                        android:id="@+id/rowSourceLang" />

                    <include layout="@layout/settings_row_divider" />

                    <include layout="@layout/settings_row_value"
                        android:id="@+id/rowTargetLang" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- ON-SCREEN CONTROLS                                    -->
            <!-- ══════════════════════════════════════════════════════ -->

            <include layout="@layout/settings_group_header"
                android:id="@+id/headerOnScreen" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/ptCard"
                app:cardCornerRadius="@dimen/pt_radius"
                app:cardElevation="0dp"
                app:strokeColor="?attr/ptDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/settings_row_switch"
                        android:id="@+id/rowOverlayIcon" />

                    <View
                        android:id="@+id/dividerCompactIcon"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/pt_row_h_padding"
                        android:background="?attr/ptDivider" />

                    <include layout="@layout/settings_row_switch"
                        android:id="@+id/rowCompactIcon" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- AUTO-TRANSLATE                                        -->
            <!-- ══════════════════════════════════════════════════════ -->

            <include layout="@layout/settings_group_header"
                android:id="@+id/headerAutoTranslate" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAutoTranslate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/ptCard"
                app:cardCornerRadius="@dimen/pt_radius"
                app:cardElevation="0dp"
                app:strokeColor="?attr/ptDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Overlay mode section (conditional: only when language has hint text) -->
                    <LinearLayout
                        android:id="@+id/overlayModeSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/pt_row_h_padding"
                        android:paddingVertical="@dimen/pt_row_v_padding"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Overlay Mode"
                            style="@style/Text.PT.RowTitle" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="What overlays to show during auto mode or hold-to-preview."
                            style="@style/Text.PT.RowSubtitle" />

                        <!-- Pill segmented control (built programmatically) -->
                        <FrameLayout
                            android:id="@+id/overlayModeToggleContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/dividerOverlayMode"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/pt_row_h_padding"
                        android:background="?attr/ptDivider"
                        android:visibility="gone" />

                    <!-- Hide overlays toggle (conditional: multi-screen only) -->
                    <include layout="@layout/settings_row_switch"
                        android:id="@+id/rowHideOverlays"
                        android:visibility="gone" />

                    <View
                        android:id="@+id/dividerHideOverlays"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/pt_row_h_padding"
                        android:background="?attr/ptDivider" />

                    <!-- Capture interval (value-row style) -->
                    <LinearLayout
                        android:id="@+id/rowCaptureInterval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/pt_row_min_height"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/pt_row_h_padding"
                        android:paddingVertical="@dimen/pt_row_v_padding"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Capture interval"
                                style="@style/Text.PT.RowTitle" />

                            <TextView
                                android:id="@+id/tvCaptureIntervalHint"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                style="@style/Text.PT.RowSubtitle" />
                        </LinearLayout>

                        <EditText
                            android:id="@+id/etCaptureInterval"
                            android:layout_width="48dp"
                            android:layout_height="32dp"
                            android:gravity="center"
                            android:textSize="13sp"
                            android:textColor="?attr/ptTextMuted"
                            android:background="@android:color/transparent"
                            android:inputType="numberDecimal"
                            android:maxLength="3"
                            android:imeOptions="actionDone"
                            android:importantForAutofill="no" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="s"
                            android:layout_marginEnd="4dp"
                            style="@style/Text.PT.RowValue" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            android:tint="?attr/ptTextMuted"
                            android:importantForAccessibility="no" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- HOTKEYS (conditional: only when language has hint text) -->
            <!-- ══════════════════════════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/hotkeySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <include layout="@layout/settings_group_header"
                    android:id="@+id/headerHotkeys" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/ptCard"
                    app:cardCornerRadius="@dimen/pt_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/ptDivider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <include layout="@layout/settings_row_hotkey"
                            android:id="@+id/rowHotkeyTranslation" />

                        <View
                            android:id="@+id/dividerHotkeyFurigana"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="@dimen/pt_row_h_padding"
                            android:background="?attr/ptDivider" />

                        <include layout="@layout/settings_row_hotkey"
                            android:id="@+id/rowHotkeyFurigana" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- CAPTURE DISPLAY (conditional: multi-display)          -->
            <!-- ══════════════════════════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/captureDisplaySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <include layout="@layout/settings_group_header"
                    android:id="@+id/headerCaptureDisplay" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/ptCard"
                    app:cardCornerRadius="@dimen/pt_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/ptDivider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:id="@+id/llDisplayOptions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/pt_row_h_padding" />

                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- TRANSLATION SERVICE                                   -->
            <!-- ══════════════════════════════════════════════════════ -->

            <include layout="@layout/settings_group_header"
                android:id="@+id/headerTranslationService" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/ptCard"
                app:cardCornerRadius="@dimen/pt_radius"
                app:cardElevation="0dp"
                app:strokeColor="?attr/ptDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- DeepL API key input -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/pt_row_h_padding"
                        android:paddingVertical="@dimen/pt_row_v_padding">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DeepL API Key"
                            style="@style/Text.PT.RowTitle" />

                        <EditText
                            android:id="@+id/etDeeplKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="@string/hint_deepl_key"
                            android:textColorHint="?attr/ptTextHint"
                            android:textColor="?attr/ptText"
                            android:textSize="13sp"
                            android:fontFamily="monospace"
                            android:singleLine="true"
                            android:background="?attr/ptSurface"
                            android:padding="10dp"
                            android:importantForAutofill="no" />
                    </LinearLayout>

                    <include layout="@layout/settings_row_divider" />

                    <include layout="@layout/settings_row_link"
                        android:id="@+id/rowDeeplLink" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- ANKI                                                  -->
            <!-- ══════════════════════════════════════════════════════ -->

            <include layout="@layout/settings_group_header"
                android:id="@+id/headerAnki" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/ptCard"
                app:cardCornerRadius="@dimen/pt_radius"
                app:cardElevation="0dp"
                app:strokeColor="?attr/ptDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAnkiSectionTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/pt_row_h_padding"
                        android:paddingTop="@dimen/pt_row_v_padding"
                        android:visibility="gone"
                        style="@style/Text.PT.RowTitle" />

                    <LinearLayout
                        android:id="@+id/llAnkiGetApp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/llAnkiPermission"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone" />

                    <include layout="@layout/settings_row_value"
                        android:id="@+id/rowAnkiDeck"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- APPEARANCE                                            -->
            <!-- ══════════════════════════════════════════════════════ -->

            <include layout="@layout/settings_group_header"
                android:id="@+id/headerAppearance" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/ptCard"
                app:cardCornerRadius="@dimen/pt_radius"
                app:cardElevation="0dp"
                app:strokeColor="?attr/ptDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/llThemePicker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/pt_row_h_padding" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- SUPPORT                                               -->
            <!-- ══════════════════════════════════════════════════════ -->

            <include layout="@layout/settings_group_header"
                android:id="@+id/headerSupport" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/ptCard"
                app:cardCornerRadius="@dimen/pt_radius"
                app:cardElevation="0dp"
                app:strokeColor="?attr/ptDivider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/settings_row_link"
                        android:id="@+id/rowDiscord" />

                    <include layout="@layout/settings_row_divider" />

                    <include layout="@layout/settings_row_link"
                        android:id="@+id/rowExportLogs" />

                    <include layout="@layout/settings_row_divider" />

                    <include layout="@layout/settings_row_link"
                        android:id="@+id/rowDonate" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- DEBUG (debug builds only)                             -->
            <!-- ══════════════════════════════════════════════════════ -->

            <LinearLayout
                android:id="@+id/llDebugSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <include layout="@layout/settings_group_header"
                    android:id="@+id/headerDebug" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/ptCard"
                    app:cardCornerRadius="@dimen/pt_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/ptDivider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <include layout="@layout/settings_row_switch"
                            android:id="@+id/rowForceSingleScreen" />

                        <include layout="@layout/settings_row_divider" />

                        <include layout="@layout/settings_row_switch"
                            android:id="@+id/rowShowOcrBoxes" />

                        <include layout="@layout/settings_row_divider" />

                        <include layout="@layout/settings_row_switch"
                            android:id="@+id/rowDetectionLog" />

                        <include layout="@layout/settings_row_divider" />

                        <include layout="@layout/settings_row_action"
                            android:id="@+id/rowForceCrash" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Footer -->
            <include layout="@layout/settings_footer" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
