<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Japanese label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/section_original"
        android:textColor="?attr/ptTextMuted"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etSentenceJapanese"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="?attr/ptText"
        android:textSize="15sp"
        android:minLines="2"
        android:gravity="top|start"
        android:background="?attr/ptCard"
        android:padding="10dp"
        android:inputType="textMultiLine"
        android:layout_marginBottom="16dp" />

    <!-- Translation label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/section_translation"
        android:textColor="?attr/ptTextMuted"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etSentenceTranslation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="?attr/ptText"
        android:textSize="14sp"
        android:minLines="2"
        android:gravity="top|start"
        android:background="?attr/ptCard"
        android:padding="10dp"
        android:inputType="textMultiLine"
        android:layout_marginBottom="16dp" />

    <!-- Vocabulary label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/section_words"
        android:textColor="?attr/ptTextMuted"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:id="@+id/sentenceDefinitionsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <!-- Screenshot (visibility set in code) -->
    <TextView
        android:id="@+id/tvSentencePhotoLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_screenshot"
        android:textColor="?attr/ptTextMuted"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/layoutSentencePhoto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivSentencePhoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:background="?attr/ptCard" />

        <Button
            android:id="@+id/btnSentenceRemovePhoto"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_margin="4dp"
            android:text="@string/btn_remove_photo"
            android:textSize="11sp"
            android:backgroundTint="#CC000000"
            android:textColor="#FFFFFF" />

    </FrameLayout>

</LinearLayout>
