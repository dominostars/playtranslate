<?xml version="1.0" encoding="utf-8"?>
<!-- Tatoeba attribution footer: fills the last row of the "More examples"
     card with a subtle surface tint and draws a hairline divider on top to
     break it away from the sentence list above. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/ptSurface" />
        </shape>
    </item>
    <item android:top="0dp" android:bottom="-1dp" android:left="-1dp" android:right="-1dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="?attr/ptDivider" />
        </shape>
    </item>
</layer-list>
