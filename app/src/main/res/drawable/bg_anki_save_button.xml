<?xml version="1.0" encoding="utf-8"?>
<!-- Custom ripple-over-accent background for the Anki sheet's bottom
     "Save Anki Card" CTA. Replaces the MaterialButton's default style
     so we can host a two-line label (title + deck subtitle) inside a
     plain clickable FrameLayout. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33FFFFFF">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="@dimen/pt_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/ptAccent" />
            <corners android:radius="@dimen/pt_radius" />
        </shape>
    </item>
</ripple>
