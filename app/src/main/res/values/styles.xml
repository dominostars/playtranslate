<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base themes — define the semantic pt* colour tokens (palette only).
        Accent attributes (ptAccent, ptAccentTint, ptTextLink) are defaulted
        to Teal here, but are overridden at runtime by one of the
        ThemeOverlay.PT.Accent.* overlays via theme.applyStyle().
        See ThemeUtils.applyTheme().
    -->
    <!-- Parent is .Dark (not .DayNight): when the user explicitly picks
         Dark in-app while the system is in Light mode, DayNight still resolves
         Material color slots (colorSurface, colorOnSurface, …) against the
         system's light values. AppBarLayout.liftOnScroll then tints the app
         bar with white-ish colorSurface while ?attr/ptText is white (dark
         palette), producing white-on-white. Pinning to .Dark here decouples
         our explicit theme choice from the system uiMode. .White below stays
         on .Light for the symmetric reason. -->
    <style name="Theme.PlayTranslate" parent="Theme.Material3.Dark.NoActionBar">

        <!-- ── Dark palette ──────────────────────────────────────────────── -->
        <item name="ptBg">@color/pt_dark_bg</item>
        <item name="ptSurface">@color/pt_dark_surface</item>
        <item name="ptCard">@color/pt_dark_card</item>
        <item name="ptElevated">@color/pt_dark_elevated</item>
        <item name="ptDivider">@color/pt_dark_divider</item>
        <item name="ptOutline">@color/pt_dark_outline</item>
        <item name="ptText">@color/pt_dark_text</item>
        <item name="ptTextMuted">@color/pt_dark_text_muted</item>
        <item name="ptTextHint">@color/pt_dark_text_hint</item>
        <item name="ptTextTranslation">@color/pt_dark_translation</item>
        <item name="ptAccentOn">@color/pt_dark_text_on_accent</item>
        <item name="ptDanger">@color/pt_dark_danger</item>
        <item name="ptWarning">@color/pt_dark_warning</item>
        <item name="ptRadius">14dp</item>

        <!-- ── Accent fallback (Teal) — overridden by accent overlay ─────── -->
        <item name="ptAccent">@color/pt_accent_teal</item>
        <item name="ptAccentTint">@color/pt_accent_teal_tint</item>
        <item name="ptTextLink">@color/pt_accent_teal</item>

        <!-- ── Material component mapping ────────────────────────────────── -->
        <!-- Mirror Theme.PlayTranslate.White's mapping so Material widgets
             (AppBarLayout liftOnScroll, MaterialCardView elevation overlay,
             MaterialButton etc.) all resolve against the dark pt* palette
             instead of falling back to Material3.Dark's stock surface tones. -->
        <item name="colorPrimary">?attr/ptAccent</item>
        <item name="colorOnPrimary">?attr/ptAccentOn</item>
        <item name="colorPrimaryContainer">?attr/ptAccent</item>
        <item name="colorOnPrimaryContainer">?attr/ptAccentOn</item>
        <item name="colorPrimaryDark">?attr/ptAccent</item>
        <item name="colorAccent">?attr/ptAccent</item>
        <item name="colorSurface">?attr/ptSurface</item>
        <item name="colorOnSurface">?attr/ptText</item>
        <item name="colorOnSurfaceVariant">?attr/ptTextMuted</item>
        <item name="colorOutline">?attr/ptDivider</item>
        <item name="android:windowBackground">?attr/ptBg</item>
        <item name="android:statusBarColor">?attr/ptBg</item>
        <item name="android:navigationBarColor">?attr/ptBg</item>
        <item name="android:textColor">?attr/ptText</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="materialSwitchStyle">@style/Widget.PlayTranslate.MaterialSwitch</item>
    </style>

    <!-- ── Light palette ──────────────────────────────────────────────────── -->
    <style name="Theme.PlayTranslate.White" parent="Theme.Material3.Light.NoActionBar">
        <item name="ptBg">@color/pt_light_bg</item>
        <item name="ptSurface">@color/pt_light_surface</item>
        <item name="ptCard">@color/pt_light_card</item>
        <item name="ptElevated">@color/pt_light_elevated</item>
        <item name="ptDivider">@color/pt_light_divider</item>
        <item name="ptOutline">@color/pt_light_outline</item>
        <item name="ptText">@color/pt_light_text</item>
        <item name="ptTextMuted">@color/pt_light_text_muted</item>
        <item name="ptTextHint">@color/pt_light_text_hint</item>
        <item name="ptTextTranslation">@color/pt_light_translation</item>
        <item name="ptAccentOn">@color/pt_light_text_on_accent</item>
        <item name="ptDanger">@color/pt_light_danger</item>
        <item name="ptWarning">@color/pt_light_warning</item>
        <item name="ptRadius">14dp</item>

        <!-- ── Accent fallback (Teal) — overridden by accent overlay ─────── -->
        <item name="ptAccent">@color/pt_accent_teal</item>
        <item name="ptAccentTint">@color/pt_accent_teal_tint</item>
        <item name="ptTextLink">@color/pt_accent_teal</item>

        <item name="colorPrimary">?attr/ptAccent</item>
        <item name="colorOnPrimary">?attr/ptAccentOn</item>
        <item name="colorPrimaryContainer">?attr/ptAccent</item>
        <item name="colorOnPrimaryContainer">?attr/ptAccentOn</item>
        <item name="colorPrimaryDark">?attr/ptAccent</item>
        <item name="colorAccent">?attr/ptAccent</item>
        <item name="colorSurface">?attr/ptSurface</item>
        <item name="colorOnSurface">?attr/ptText</item>
        <item name="colorOnSurfaceVariant">?attr/ptTextMuted</item>
        <item name="colorOutline">?attr/ptDivider</item>
        <item name="android:windowBackground">?attr/ptBg</item>
        <item name="android:statusBarColor">?attr/ptBg</item>
        <item name="android:navigationBarColor">?attr/ptBg</item>
        <item name="android:textColor">?attr/ptText</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="materialSwitchStyle">@style/Widget.PlayTranslate.MaterialSwitch</item>
    </style>

    <!-- ── Full-screen dialog overlays ──────────────────────────────────── -->
    <style name="Theme.PlayTranslate.FullScreenDialog" parent="Theme.PlayTranslate">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:windowBackground">?attr/ptSurface</item>
        <item name="android:statusBarColor">?attr/ptSurface</item>
    </style>

    <style name="Theme.PlayTranslate.White.FullScreenDialog" parent="Theme.PlayTranslate.White">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:windowBackground">?attr/ptSurface</item>
        <item name="android:statusBarColor">?attr/ptSurface</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- Accent overlays — applied on top of either base theme via         -->
    <!-- theme.applyStyle(R.style.ThemeOverlay_PT_Accent_<Name>, true).    -->
    <!-- Each overrides the three accent slots; everything else inherits.  -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <style name="ThemeOverlay.PT.Accent.Coral" parent="">
        <item name="ptAccent">@color/pt_accent_coral</item>
        <item name="ptAccentTint">@color/pt_accent_coral_tint</item>
        <item name="ptTextLink">@color/pt_accent_coral</item>
    </style>

    <style name="ThemeOverlay.PT.Accent.Amber" parent="">
        <item name="ptAccent">@color/pt_accent_amber</item>
        <item name="ptAccentTint">@color/pt_accent_amber_tint</item>
        <item name="ptTextLink">@color/pt_accent_amber</item>
    </style>

    <style name="ThemeOverlay.PT.Accent.Lime" parent="">
        <item name="ptAccent">@color/pt_accent_lime</item>
        <item name="ptAccentTint">@color/pt_accent_lime_tint</item>
        <item name="ptTextLink">@color/pt_accent_lime</item>
    </style>

    <style name="ThemeOverlay.PT.Accent.Mint" parent="">
        <item name="ptAccent">@color/pt_accent_mint</item>
        <item name="ptAccentTint">@color/pt_accent_mint_tint</item>
        <item name="ptTextLink">@color/pt_accent_mint</item>
    </style>

    <style name="ThemeOverlay.PT.Accent.Teal" parent="">
        <item name="ptAccent">@color/pt_accent_teal</item>
        <item name="ptAccentTint">@color/pt_accent_teal_tint</item>
        <item name="ptTextLink">@color/pt_accent_teal</item>
    </style>

    <style name="ThemeOverlay.PT.Accent.Sky" parent="">
        <item name="ptAccent">@color/pt_accent_sky</item>
        <item name="ptAccentTint">@color/pt_accent_sky_tint</item>
        <item name="ptTextLink">@color/pt_accent_sky</item>
    </style>

    <style name="ThemeOverlay.PT.Accent.Steel" parent="">
        <item name="ptAccent">@color/pt_accent_steel</item>
        <item name="ptAccentTint">@color/pt_accent_steel_tint</item>
        <item name="ptTextLink">@color/pt_accent_steel</item>
    </style>

    <style name="ThemeOverlay.PT.Accent.Violet" parent="">
        <item name="ptAccent">@color/pt_accent_violet</item>
        <item name="ptAccentTint">@color/pt_accent_violet_tint</item>
        <item name="ptTextLink">@color/pt_accent_violet</item>
    </style>

    <style name="ThemeOverlay.PT.Accent.Orchid" parent="">
        <item name="ptAccent">@color/pt_accent_orchid</item>
        <item name="ptAccentTint">@color/pt_accent_orchid_tint</item>
        <item name="ptTextLink">@color/pt_accent_orchid</item>
    </style>

    <style name="ThemeOverlay.PT.Accent.Rose" parent="">
        <item name="ptAccent">@color/pt_accent_rose</item>
        <item name="ptAccentTint">@color/pt_accent_rose_tint</item>
        <item name="ptTextLink">@color/pt_accent_rose</item>
    </style>

    <!-- ── Widget styles (reference attrs, resolve at inflation time) ───── -->

    <style name="Widget.PlayTranslate.MaterialSwitch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">@color/switch_thumb</item>
        <item name="trackTint">@color/switch_track</item>
        <item name="trackDecorationTint">@color/switch_track_decoration</item>
    </style>

    <style name="Widget.PlayTranslate.SegmentedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="backgroundTint">@color/segmented_button_bg</item>
        <item name="android:textColor">@color/segmented_button_text</item>
        <item name="strokeColor">@color/segmented_button_stroke</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.PlayTranslate.SectionLabel" parent="">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">?attr/ptTextMuted</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="Widget.PlayTranslate.TranslationText" parent="">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">?attr/ptTextTranslation</item>
        <item name="android:lineSpacingMultiplier">1</item>
    </style>

    <!-- ── Settings row typography ──────────────────────────────────────── -->

    <style name="Text.PT.RowTitle" parent="">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">?attr/ptText</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Text.PT.RowSubtitle" parent="">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">?attr/ptTextMuted</item>
        <item name="android:lineSpacingMultiplier">1.35</item>
    </style>

    <style name="Text.PT.GroupHeader" parent="">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">?attr/ptTextMuted</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Text.PT.RowValue" parent="">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">?attr/ptTextMuted</item>
    </style>

    <style name="Text.PT.Hint" parent="">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">?attr/ptTextMuted</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="Text.PT.KeyCap" parent="">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">?attr/ptAccent</item>
        <item name="android:background">@drawable/bg_keycap</item>
        <item name="android:paddingHorizontal">7dp</item>
        <item name="android:paddingVertical">3dp</item>
    </style>

    <!-- Enter from bottom, exit to bottom (word/sentence detail) -->
    <style name="AnimSlideBottom">
        <item name="android:windowEnterAnimation">@anim/slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/slide_out_bottom</item>
    </style>

    <!-- Enter from right, exit to right (settings, anki review) -->
    <style name="AnimSlideRight">
        <item name="android:windowEnterAnimation">@anim/slide_in_right</item>
        <item name="android:windowExitAnimation">@anim/slide_out_right</item>
    </style>

</resources>
