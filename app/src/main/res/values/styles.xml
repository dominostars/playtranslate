<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base theme — defines the custom colour attrs and maps them into the
        Material component colour system.  Acts as the DEFAULT (Black) theme.
    -->
    <style name="Theme.PlayTranslate" parent="Theme.MaterialComponents.NoActionBar">

        <!-- ── Black palette (default) ───────────────────────────────────── -->
        <item name="colorBgDark">#0D0D0D</item>
        <item name="colorBgSurface">#1A1A1A</item>
        <item name="colorBgCard">#242424</item>
        <item name="colorBgDivider">#2E2E2E</item>
        <item name="colorAccentPrimary">#00BCD4</item>
        <item name="colorAccentPrimaryDark">#0097A7</item>
        <item name="colorAccentSecondary">#80DEEA</item>
        <item name="colorTextPrimary">#EFEFEF</item>
        <item name="colorTextSecondary">#A0A0A0</item>
        <item name="colorTextHint">#606060</item>
        <item name="colorTextTranslation">#E8C07A</item>
        <item name="colorTextLink">#00BCD4</item>
        <item name="colorTextOnAccent">#000000</item>

        <!-- ── Material component mapping ────────────────────────────────── -->
        <item name="colorPrimary">?attr/colorAccentPrimary</item>
        <item name="colorPrimaryDark">?attr/colorAccentPrimaryDark</item>
        <item name="colorAccent">?attr/colorAccentPrimary</item>
        <item name="android:windowBackground">?attr/colorBgDark</item>
        <item name="android:statusBarColor">?attr/colorBgDark</item>
        <item name="android:navigationBarColor">?attr/colorBgDark</item>
        <item name="android:textColor">?attr/colorTextPrimary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- ── White theme ────────────────────────────────────────────────────── -->
    <style name="Theme.PlayTranslate.White" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorBgDark">#F0F0F0</item>
        <item name="colorBgSurface">#E8E8E8</item>
        <item name="colorBgCard">#DCDCDC</item>
        <item name="colorBgDivider">#C0C0C0</item>
        <item name="colorAccentPrimary">#1565C0</item>
        <item name="colorAccentPrimaryDark">#0D47A1</item>
        <item name="colorAccentSecondary">#90CAF9</item>
        <item name="colorTextPrimary">#1C1C1C</item>
        <item name="colorTextSecondary">#505050</item>
        <item name="colorTextHint">#909090</item>
        <item name="colorTextTranslation">#B34700</item>
        <item name="colorTextLink">#1565C0</item>
        <item name="colorTextOnAccent">#FFFFFF</item>
        <item name="colorPrimary">?attr/colorAccentPrimary</item>
        <item name="colorPrimaryDark">?attr/colorAccentPrimaryDark</item>
        <item name="colorAccent">?attr/colorAccentPrimary</item>
        <item name="android:windowBackground">?attr/colorBgDark</item>
        <item name="android:statusBarColor">?attr/colorBgDark</item>
        <item name="android:navigationBarColor">?attr/colorBgDark</item>
        <item name="android:textColor">?attr/colorTextPrimary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- ── Rainbow / Granite theme ────────────────────────────────────────── -->
    <style name="Theme.PlayTranslate.Rainbow" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorBgDark">#C8C4C1</item>
        <item name="colorBgSurface">#D8D4D1</item>
        <item name="colorBgCard">#E2DEDD</item>
        <item name="colorBgDivider">#B5B1AE</item>
        <item name="colorAccentPrimary">#546E7A</item>
        <item name="colorAccentPrimaryDark">#37474F</item>
        <item name="colorAccentSecondary">#B0BEC5</item>
        <item name="colorTextPrimary">#1A1A1A</item>
        <item name="colorTextSecondary">#4A4745</item>
        <item name="colorTextHint">#8A8785</item>
        <item name="colorTextTranslation">#6D4C41</item>
        <item name="colorTextLink">#546E7A</item>
        <item name="colorTextOnAccent">#FFFFFF</item>
        <item name="colorPrimary">?attr/colorAccentPrimary</item>
        <item name="colorPrimaryDark">?attr/colorAccentPrimaryDark</item>
        <item name="colorAccent">?attr/colorAccentPrimary</item>
        <item name="android:windowBackground">?attr/colorBgDark</item>
        <item name="android:statusBarColor">?attr/colorBgDark</item>
        <item name="android:navigationBarColor">?attr/colorBgDark</item>
        <item name="android:textColor">?attr/colorTextPrimary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- ── Purple theme ───────────────────────────────────────────────────── -->
    <style name="Theme.PlayTranslate.Purple" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorBgDark">#221929</item>
        <item name="colorBgSurface">#2E2238</item>
        <item name="colorBgCard">#3A2C47</item>
        <item name="colorBgDivider">#4A3B58</item>
        <item name="colorAccentPrimary">#CE93D8</item>
        <item name="colorAccentPrimaryDark">#AB47BC</item>
        <item name="colorAccentSecondary">#E1BEE7</item>
        <item name="colorTextPrimary">#F0EBF4</item>
        <item name="colorTextSecondary">#B0A5BA</item>
        <item name="colorTextHint">#6E6176</item>
        <item name="colorTextTranslation">#FFCC80</item>
        <item name="colorTextLink">#CE93D8</item>
        <item name="colorTextOnAccent">#000000</item>
        <item name="colorPrimary">?attr/colorAccentPrimary</item>
        <item name="colorPrimaryDark">?attr/colorAccentPrimaryDark</item>
        <item name="colorAccent">?attr/colorAccentPrimary</item>
        <item name="android:windowBackground">?attr/colorBgDark</item>
        <item name="android:statusBarColor">?attr/colorBgDark</item>
        <item name="android:navigationBarColor">?attr/colorBgDark</item>
        <item name="android:textColor">?attr/colorTextPrimary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- ── Full-screen dialog overlays (one per theme) ────────────────────── -->
    <style name="Theme.PlayTranslate.FullScreenDialog" parent="Theme.PlayTranslate">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:windowBackground">?attr/colorBgSurface</item>
        <item name="android:statusBarColor">?attr/colorBgSurface</item>
    </style>

    <style name="Theme.PlayTranslate.White.FullScreenDialog" parent="Theme.PlayTranslate.White">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:windowBackground">?attr/colorBgSurface</item>
        <item name="android:statusBarColor">?attr/colorBgSurface</item>
    </style>

    <style name="Theme.PlayTranslate.Rainbow.FullScreenDialog" parent="Theme.PlayTranslate.Rainbow">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:windowBackground">?attr/colorBgSurface</item>
        <item name="android:statusBarColor">?attr/colorBgSurface</item>
    </style>

    <style name="Theme.PlayTranslate.Purple.FullScreenDialog" parent="Theme.PlayTranslate.Purple">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:windowBackground">?attr/colorBgSurface</item>
        <item name="android:statusBarColor">?attr/colorBgSurface</item>
    </style>

    <!-- ── Widget styles (reference attrs, resolve at inflation time) ───── -->

    <style name="Widget.PlayTranslate.ModeButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="cornerRadius">20dp</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.PlayTranslate.Card" parent="">
        <item name="android:background">?attr/colorBgCard</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="Widget.PlayTranslate.SectionLabel" parent="Widget.MaterialComponents.TextView">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">?attr/colorTextSecondary</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="Widget.PlayTranslate.OriginalText" parent="Widget.MaterialComponents.TextView">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">?attr/colorTextPrimary</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <style name="Widget.PlayTranslate.TranslationText" parent="Widget.MaterialComponents.TextView">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">?attr/colorTextTranslation</item>
        <item name="android:lineSpacingMultiplier">1</item>
    </style>

    <!-- Transparent bridge activity (no color theming needed) -->
    <style name="Theme.PlayTranslate.Transparent" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Enter from bottom, exit to bottom (word/sentence detail) -->
    <style name="AnimSlideBottom">
        <item name="android:windowEnterAnimation">@anim/slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/slide_out_bottom</item>
    </style>

    <!-- Enter from right, exit to right (settings, anki review) -->
    <style name="AnimSlideRight">
        <item name="android:windowEnterAnimation">@anim/slide_in_right</item>
        <item name="android:windowExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="Theme.PlayTranslate.BottomSheetDialog" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.PlayTranslate.BottomSheet</item>
        <item name="android:windowIsFloating">false</item>
    </style>

    <style name="Widget.PlayTranslate.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="android:background">?attr/colorBgSurface</item>
        <item name="backgroundTint">?attr/colorBgSurface</item>
    </style>


</resources>
