<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base theme — defines the semantic pt* colour tokens and maps them
        into the Material component colour system.
        Acts as the DEFAULT (Black) theme.
    -->
    <style name="Theme.PlayTranslate" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- ── Dark palette + teal accent ────────────────────────────────── -->
        <item name="ptBg">@color/pt_dark_bg</item>
        <item name="ptSurface">@color/pt_dark_surface</item>
        <item name="ptCard">@color/pt_dark_card</item>
        <item name="ptElevated">@color/pt_dark_elevated</item>
        <item name="ptDivider">@color/pt_dark_divider</item>
        <item name="ptOutline">@color/pt_dark_outline</item>
        <item name="ptText">@color/pt_dark_text</item>
        <item name="ptTextMuted">@color/pt_dark_text_muted</item>
        <item name="ptTextHint">@color/pt_dark_text_hint</item>
        <item name="ptTextTranslation">@color/pt_dark_translation</item>
        <item name="ptTextLink">@color/pt_accent_teal</item>
        <item name="ptAccent">@color/pt_accent_teal</item>
        <item name="ptAccentTint">@color/pt_accent_teal_tint_dark</item>
        <item name="ptAccentOn">@color/pt_dark_text_on_accent</item>
        <item name="ptDanger">@color/pt_dark_danger</item>
        <item name="ptWarning">@color/pt_dark_warning</item>
        <item name="ptRadius">14dp</item>

        <!-- ── Material component mapping ────────────────────────────────── -->
        <item name="colorPrimary">?attr/ptAccent</item>
        <item name="colorPrimaryDark">?attr/ptAccent</item>
        <item name="colorAccent">?attr/ptAccent</item>
        <item name="android:windowBackground">?attr/ptBg</item>
        <item name="android:statusBarColor">?attr/ptBg</item>
        <item name="android:navigationBarColor">?attr/ptBg</item>
        <item name="android:textColor">?attr/ptText</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="materialSwitchStyle">@style/Widget.PlayTranslate.MaterialSwitch</item>
    </style>

    <!-- ── White theme (Light palette + teal accent) ─────────────────────── -->
    <style name="Theme.PlayTranslate.White" parent="Theme.Material3.Light.NoActionBar">
        <item name="ptBg">@color/pt_light_bg</item>
        <item name="ptSurface">@color/pt_light_surface</item>
        <item name="ptCard">@color/pt_light_card</item>
        <item name="ptElevated">@color/pt_light_elevated</item>
        <item name="ptDivider">@color/pt_light_divider</item>
        <item name="ptOutline">@color/pt_light_outline</item>
        <item name="ptText">@color/pt_light_text</item>
        <item name="ptTextMuted">@color/pt_light_text_muted</item>
        <item name="ptTextHint">@color/pt_light_text_hint</item>
        <item name="ptTextTranslation">@color/pt_light_translation</item>
        <item name="ptTextLink">@color/pt_accent_teal</item>
        <item name="ptAccent">@color/pt_accent_teal</item>
        <item name="ptAccentTint">@color/pt_accent_teal_tint_light</item>
        <item name="ptAccentOn">@color/pt_light_text_on_accent</item>
        <item name="ptDanger">@color/pt_light_danger</item>
        <item name="ptWarning">@color/pt_light_warning</item>
        <item name="ptRadius">14dp</item>
        <item name="colorPrimary">?attr/ptAccent</item>
        <item name="colorOnPrimary">?attr/ptAccentOn</item>
        <item name="colorPrimaryContainer">?attr/ptAccent</item>
        <item name="colorOnPrimaryContainer">?attr/ptAccentOn</item>
        <item name="colorPrimaryDark">?attr/ptAccent</item>
        <item name="colorAccent">?attr/ptAccent</item>
        <item name="colorSurface">?attr/ptSurface</item>
        <item name="colorOnSurface">?attr/ptText</item>
        <item name="colorOnSurfaceVariant">?attr/ptTextMuted</item>
        <item name="colorOutline">?attr/ptDivider</item>
        <item name="android:windowBackground">?attr/ptBg</item>
        <item name="android:statusBarColor">?attr/ptBg</item>
        <item name="android:navigationBarColor">?attr/ptBg</item>
        <item name="android:textColor">?attr/ptText</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="materialSwitchStyle">@style/Widget.PlayTranslate.MaterialSwitch</item>
    </style>

    <!-- ── Rainbow theme (Light palette + coral accent) ──────────────────── -->
    <style name="Theme.PlayTranslate.Rainbow" parent="Theme.Material3.Light.NoActionBar">
        <item name="ptBg">@color/pt_light_bg</item>
        <item name="ptSurface">@color/pt_light_surface</item>
