    <!-- ── Purple theme (Dark palette + purple accent) ───────────────────── -->
    <style name="Theme.PlayTranslate.Purple" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="ptBg">@color/pt_dark_bg</item>
        <item name="ptSurface">@color/pt_dark_surface</item>
        <item name="ptCard">@color/pt_dark_card</item>
        <item name="ptElevated">@color/pt_dark_elevated</item>
        <item name="ptDivider">@color/pt_dark_divider</item>
        <item name="ptOutline">@color/pt_dark_outline</item>
        <item name="ptText">@color/pt_dark_text</item>
        <item name="ptTextMuted">@color/pt_dark_text_muted</item>
        <item name="ptTextHint">@color/pt_dark_text_hint</item>
        <item name="ptTextTranslation">@color/pt_dark_translation</item>
        <item name="ptTextLink">@color/pt_accent_purple</item>
        <item name="ptAccent">@color/pt_accent_purple</item>
        <item name="ptAccentTint">@color/pt_accent_purple_tint</item>
        <item name="ptAccentOn">@color/pt_dark_text_on_accent</item>
        <item name="ptDanger">@color/pt_dark_danger</item>
        <item name="ptWarning">@color/pt_dark_warning</item>
        <item name="ptRadius">14dp</item>
        <item name="colorPrimary">?attr/ptAccent</item>
        <item name="colorOnPrimary">?attr/ptAccentOn</item>
        <item name="colorPrimaryContainer">?attr/ptAccent</item>
        <item name="colorOnPrimaryContainer">?attr/ptAccentOn</item>
        <item name="colorPrimaryDark">?attr/ptAccent</item>
        <item name="colorAccent">?attr/ptAccent</item>
        <item name="colorSurface">?attr/ptSurface</item>
