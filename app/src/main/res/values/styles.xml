        <item name="colorTextPrimary">#1C1C1C</item>
        <item name="colorTextSecondary">#505050</item>
        <item name="colorTextHint">#909090</item>
        <item name="colorTextTranslation">#B34700</item>
        <item name="colorTextLink">#1565C0</item>
        <item name="colorTextOnAccent">#FFFFFF</item>
        <item name="colorPrimary">?attr/colorAccentPrimary</item>
        <item name="colorOnPrimary">?attr/colorTextOnAccent</item>
        <item name="colorPrimaryContainer">?attr/colorAccentPrimary</item>
        <item name="colorOnPrimaryContainer">?attr/colorTextOnAccent</item>
        <item name="colorPrimaryDark">?attr/colorAccentPrimaryDark</item>
        <item name="colorAccent">?attr/colorAccentPrimary</item>
        <item name="colorSurface">?attr/colorBgSurface</item>
        <item name="colorOnSurface">?attr/colorTextPrimary</item>
        <item name="colorOnSurfaceVariant">?attr/colorTextSecondary</item>
        <item name="colorOutline">?attr/colorBgDivider</item>
        <item name="android:windowBackground">?attr/colorBgDark</item>
        <item name="android:statusBarColor">?attr/colorBgDark</item>
        <item name="android:navigationBarColor">?attr/colorBgDark</item>
        <item name="android:textColor">?attr/colorTextPrimary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="materialSwitchStyle">@style/Widget.PlayTranslate.MaterialSwitch</item>

        <!-- ── Semantic tokens (Light) ────────────────────────────────── -->
        <item name="ptBg">?attr/colorBgDark</item>
        <item name="ptSurface">?attr/colorBgSurface</item>
        <item name="ptCard">?attr/colorBgCard</item>
